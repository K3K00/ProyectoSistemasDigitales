/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();

  EjecutarSecuencia();
  while (1)
  {
    while(!VerificarSW3())
    	HAL_Delay(TSONDEO); //Si SW3 esta presionado (activo bajo), entonces nos quedamos esperando hasta soltarlo.
    while(!VerificarSW2())
    	CambiarTespera();   //Si SW2 esta presionado (activo bajo), entonces cambiamos el tiempo que esta encendido el led.
    HAL_Delay(TSONDEO);
    while(!VerificarSW1())
    	CambiarModo();
  }
  /* USER CODE END 3 */
}

