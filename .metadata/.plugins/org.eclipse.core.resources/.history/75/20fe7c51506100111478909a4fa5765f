bool VerificarSW1(void) {
	static GPIO_PinState ultima_lectura_valida = GPIO_PIN_SET; //Boton liberado.
	GPIO_PinState lectura1, lectura2; //Se crean variables para lecturas intermedias.
	bool pedido = false; //No hay pedido hasta que se pulsa el botón.
	lectura1 = HAL_GPIO_ReadPin(SWITCH_GPIO_Port, SW1_Pin); //Se lee el estado del botón SW1.

	if (lectura1 != ultima_lectura_valida) { //Si la lectura del Botón SW1 es distinta de 1 (acordarse que los botones son activo bajo).
		//Se espera un tiempo para filtrar los rebotes.
		HAL_Delay(TREBOTES); //Retardo de TREBOTES ms.
		lectura2 = HAL_GPIO_ReadPin(SWITCH_GPIO_Port, SW1_Pin); //Se lee nuevamente el estado del botón SW1.
		if (lectura2 == lectura1) { //Si ambas lecturas son iguales, se pulso el botón.
			ultima_lectura_valida = lectura2;
		}
		if (ultima_lectura_valida == GPIO_PIN_RESET) //Si la última lectura es igual a 0.
			pedido = true;
	}
	return pedido; // Devuelve a VerificarSW2 si se presiono o no el botón.
}

