// Prueba inicial del sistema
void inicio(void) {
// Obtenemos el valor máximo de ciclo de trabajo de la configuración del hgardware
	uint16_t ciclomaximo = TIM4->ARR; // Valor máximo de ciclo de trabajo
// Configuramos el PWM para que inicie con los LED encendidos
	TIM4->CCR1 = ciclomaximo; // LED verde al 100 %
	TIM4->CCR2 = ciclomaximo; // LED rojo al 100 %
	TIM4->CCR4 = ciclomaximo;
// Arrancamos el PWM
	HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_1); // Inicio de la modulación PWM, LED verde
	HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_2); // Inicio de la modulación PWM, LED rojo
	HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_4);
// Mantenemos los LED encendidos por un tiempo
	HAL_Delay(TENCENDIDO); // Retardo de TENCENDIDO milisegundos
// Apagamos los LED
	TIM4->CCR1 = 0; // LED verde al 0 %
	TIM4->CCR2 = 0; // LED rojo al 0 %
	TIM4->CCR4 = 0; // LED rojo al 0 %
// Mantenemos los LED apagados por un tiempo
	HAL_Delay(TAPAGADO); // Retardo de TAPAGADO milisegundos
//Encendemos el LED rojo
	TIM4->CCR2 = ciclomaximo; // LED rojo al 100 %
}

void CambiarModo(void) {
	if (VerificarSW1()) {
		modo_actual = (modo_actual + 1) % 3;
	}
}

void CambiarLed(void) {
	if (VerificarSW2()) {
		x = (x + 1) % 3;
	}
}

void Breathing(void) {
	CambiarLed();
	uint16_t ciclomaximo = TIM4->ARR;
	switch (x) {
	case 0:
		uint16_t ciclorojo = TIM4->CCR2;
		TIM4->CCR1 = 0;
		TIM4->CCR4 = 0;
		do {
			HAL_Delay(TCAMBIO);

			ciclorojo = (ciclorojo > VALCAMBIO) ? ciclorojo - VALCAMBIO : 0;
			TIM4->CCR2 = ciclorojo;

		} while (ciclorojo > 0);

		do {
			HAL_Delay(TCAMBIO);

			ciclorojo =
					(ciclorojo + VALCAMBIO < ciclomaximo) ?
							ciclorojo + VALCAMBIO : ciclomaximo;

			TIM4->CCR2 = ciclorojo;

		} while (ciclorojo < ciclomaximo);
		break;
	case 1:
		TIM4->CCR1 = 0;
		TIM4->CCR2 = 0;
		uint16_t cicloamarillo = TIM4->CCR4;

		do {
			HAL_Delay(TCAMBIO);

			cicloamarillo =
					(cicloamarillo > VALCAMBIO) ? cicloamarillo - VALCAMBIO : 0;
			TIM4->CCR4 = cicloamarillo;

		} while (cicloamarillo > 0);

		do {
			HAL_Delay(TCAMBIO);

			cicloamarillo =
					(cicloamarillo + VALCAMBIO < ciclomaximo) ?
							cicloamarillo + VALCAMBIO : ciclomaximo;

			TIM4->CCR4 = cicloamarillo;

		} while (cicloamarillo < ciclomaximo);
		break;
	case 2:
		TIM4->CCR4 = 0;
		TIM4->CCR2 = 0;
		uint16_t cicloverde = TIM4->CCR1;

		do {
			HAL_Delay(TCAMBIO);

			cicloverde = (cicloverde > VALCAMBIO) ? cicloverde - VALCAMBIO : 0;
			TIM4->CCR1 = cicloverde;

		} while (cicloverde > 0);

		do {
			HAL_Delay(TCAMBIO);

			cicloverde =
					(cicloverde + VALCAMBIO < ciclomaximo) ?
							cicloverde + VALCAMBIO : ciclomaximo;

			TIM4->CCR1 = cicloverde;

		} while (cicloverde < ciclomaximo);
		break;
	}

}

void CambiarBlink(void) {
	if (!VerificarSW2()) {
		x = (x + 1) % 3;
	}
	if (!VerificarSW3()) {
		x = (x - 1) % 3;
	}
}

